{
  "name": "RnChatUi",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "android": "react-native run-android",
    "ios": "react-native run-ios",
    "web": "webpack serve",
    "build-web": "webpack --mode production",
    "build": "npm run build-web",
    "lint": "eslint .",
    "start": "react-native start",
    "test": "jest",
    "test:chat": "jest --runInBand --watch=false __tests__/bedrock.stream.test.ts __tests__/chat.display.test.tsx __tests__/navigation.guest.web.test.tsx __tests__/chat.conversation.test.tsx __tests__/chat.auth.display.test.tsx __tests__/chat.attachments.test.ts __tests__/chat.office.backend.test.ts",
    "test:chat:judge": "node scripts/run-chat-judge.mjs",
    "test:chat:judge:auth": "node scripts/run-chat-judge.mjs --include-auth --auth-only",
    "test:chat:judge:report": "node scripts/run-chat-judge-report.mjs",
    "test:chat:judge:models": "node scripts/list-github-models.mjs --publisher OpenAI --publisher Anthropic",
    "test:chat:smoke": "node scripts/chat.browser.smoke.mjs",
    "test:chat:smoke:artifacts": "node scripts/chat.browser.smoke.mjs --save-artifacts",
    "test:chat:smoke:auth": "node scripts/chat.browser.auth-smoke.mjs",
    "test:chat:smoke:auth:artifacts": "node scripts/chat.browser.auth-smoke.mjs --save-artifacts",
    "deploy": "npm run build && amplify publish"
  },
  "dependencies": {
    "@aws-amplify/ui-react-native": "^2.5.3",
    "@aws-sdk/client-bedrock-runtime": "^3.859.0",
    "@aws-sdk/client-cognito-identity-provider": "^3.883.0",
    "@aws-sdk/client-dynamodb": "^3.883.0",
    "@aws-sdk/client-s3": "^3.859.0",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-navigation/elements": "^1.3.31",
    "@react-navigation/native": "^6.1.18",
    "@react-navigation/native-stack": "^6.11.0",
    "@types/uuid": "^10.0.0",
    "aws-amplify": "^6.15.4",
    "react": "18.3.1",
    "react-dom": "^18.3.1",
    "react-native": "0.75.5",
    "react-native-gesture-handler": "^2.0.0",
    "react-native-reanimated": "^4.0.1",
    "react-native-safe-area-context": "^5.6.1",
    "react-native-screens": "^4.15.4",
    "react-native-web": "^0.19.0",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@babel/core": "^7.20.0",
    "@babel/plugin-proposal-class-properties": "^7.18.6",
    "@babel/plugin-transform-runtime": "^7.28.0",
    "@babel/preset-env": "^7.25.8",
    "@babel/preset-react": "^7.27.1",
    "@babel/preset-typescript": "^7.25.7",
    "@babel/runtime": "^7.20.0",
    "@react-native/babel-preset": "^0.75.5",
    "@react-native/eslint-config": "0.75.5",
    "@react-native/metro-config": "0.75.5",
    "@react-native/typescript-config": "0.75.5",
    "@types/react": "^18.2.6",
    "@types/react-test-renderer": "^18.0.0",
    "babel-jest": "^29.6.3",
    "babel-loader": "^9.2.1",
    "babel-plugin-module-resolver": "^5.0.2",
    "buffer": "^6.0.3",
    "copy-webpack-plugin": "^13.0.1",
    "crypto-browserify": "^3.12.1",
    "eslint": "^8.19.0",
    "file-loader": "^6.2.0",
    "html-webpack-plugin": "^5.6.0",
    "jest": "^29.6.3",
    "os-browserify": "^0.3.0",
    "path-browserify": "^1.0.1",
    "playwright": "^1.59.1",
    "prettier": "2.8.8",
    "process": "^0.11.10",
    "react-test-renderer": "18.3.1",
    "stream-browserify": "^3.0.0",
    "typescript": "5.0.4",
    "undici": "^6.24.1",
    "util": "^0.12.5",
    "webpack": "^5.95.0",
    "webpack-cli": "^5.1.4",
    "webpack-dev-server": "^5.1.0"
  },
  "engines": {
    "node": ">=18"
  }
}
